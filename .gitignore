# Skills copied from npm packages at install time (not committed).
# Local skills (not from npm) must be explicitly un-ignored below.
skills/*
!skills/aether/
!skills/elemental-mcp-patterns/

# Bundled instruction files (generated by scripts/publish-instructions.sh from commands/, skills/)
packages/aether-instructions/commands/
packages/aether-instructions/skills/

# Node dependencies
node_modules
.nuxt

.output

# Environment file
.env
.env.local
.env.*.local
# Environment files to keep! These are templates or use env vars, not secrets.
# .env.example - template
# .npmrc - committed: pins @yottagraph-app to GCP Artifact Registry and reads
#          the AR token from ${AR_NPM_TOKEN} at install time (no secret committed)

# Vercel project config (created by `vercel link`, unique per user)
.vercel/

# Broadchurch tenant config (created by /broadchurch_setup, may contain project-specific settings)
broadchurch.yaml

# Local-FS prefs fallback for `npm run dev` (ENG-520, ENG-534). Persists
# the per-user prefs docs across page refreshes when no Firestore is
# configured. One JSON file per user per scope.
.aether-dev-prefs/

# Per-component stack logs captured into query traces during local dev
# (see server/utils/stackLogs.ts).
.aether-dev-logs/

# Python virtual environments (for agents and MCP servers)
.venv/
agents/.venv/
agents/*/.venv/
mcp-servers/*/.venv/
# Local ADK api_server/web state (sessions, artifacts) from `adk api_server`
.adk/
agents/*/.adk/
__pycache__/
*.pyc
*.egg-info/
.pytest_cache/

# Generated API clients (legacy, can be removed)
composables/generated/
query/api/

# Avatar cache
.cache/

# Logs
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# Platform-specific
.DS_Store
Thumbs.db